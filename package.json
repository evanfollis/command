{
  "name": "command",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "check": "tsx scripts/check-patterns.ts",
    "build": "npm run check && next build && npx tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server.js",
    "smoke": "tsx scripts/smoke.ts",
    "deploy": "npm run build && systemctl restart command && sleep 2 && npm run smoke",
    "meta:scan": "tsx scripts/meta-scan.ts"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
